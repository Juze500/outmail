APP_NAME="Mail Manager"
APP_ENV=local
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=email_manager
DB_USERNAME=root
DB_PASSWORD=

# JWT — generate with: php -r "echo base64_encode(random_bytes(64));"
JWT_SECRET=REPLACE_WITH_RANDOM_64_BYTE_BASE64_STRING
JWT_TTL_MINUTES=1440

# Microsoft Azure App Registration
# 1. Go to portal.azure.com → Azure Active Directory → App registrations → New registration
# 2. Set redirect URI to: {APP_URL}/api/auth/microsoft/callback
# 3. Under "API permissions" add Delegated permissions:
#    Mail.ReadWrite, Mail.Send, offline_access, User.Read, openid, profile, email
# 4. Under "Certificates & secrets" create a client secret
MICROSOFT_CLIENT_ID=YOUR_AZURE_APP_CLIENT_ID
MICROSOFT_CLIENT_SECRET=YOUR_AZURE_APP_CLIENT_SECRET
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI="${APP_URL}/api/auth/microsoft/callback"

# 32-character key for token encryption — generate with:
# php -r "echo bin2hex(random_bytes(16));"
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_HEX_STRING

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
